DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/worldcuppy"
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# Optional – enables Google OAuth login
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Optional – comma/space separated emails that get site-owner admin tools
# SITE_OWNER_EMAILS=""

# football-data.org API (live score syncing — unlimited daily calls)
FOOTBALL_DATA_API_TOKEN=""

# api-football.com API (venue enrichment — 100 req/day free tier)
# Set directly on your container/host rather than committing a key here.
# API_FOOTBALL_TOKEN=""
