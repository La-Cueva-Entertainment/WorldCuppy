// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  isAdmin       Boolean   @default(false)
  lastSeenAt    DateTime?

  accounts             Account[]
  sessions             Session[]
  lineupPicks          LineupPick[]
  earningsAdjustments  EarningsAdjustment[]
  tournamentEntries    TournamentParticipant[]
  banterPosts          BanterPost[]
  banterReactions      BanterReaction[]
  banterReplies        BanterReply[]
  banterReplyReactions BanterReplyReaction[]
  pushSubscriptions    PushSubscription[]
}

model Tournament {
  id             String    @id @default(cuid())
  name           String
  type           String    // "world_cup" | "euros"
  year           Int
  teamsPerPlayer Int       @default(4)
  pickSeconds    Int?                // null = unlimited (no timer)
  payoutRules    Json?               // null = use DEFAULT_PAYOUT_RULES from earnings.ts
  status         String    @default("upcoming") // "upcoming" | "draft" | "active" | "complete"
  draftDate      DateTime?
  inviteToken    String?   @unique
  createdAt      DateTime  @default(now())

  draft        TournamentDraft?
  picks        LineupPick[]
  matches      Match[]
  adjustments  EarningsAdjustment[]
  participants TournamentParticipant[]
  banterPosts  BanterPost[]
}

model TournamentDraft {
  tournamentId String   @id
  status       String   @default("pending") // "pending" | "active" | "complete"
  orderUserIds String[] @default([])
  currentPick  Int      @default(0)
  updatedAt    DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([status])
}

model LineupPick {
  id           String   @id @default(cuid())
  tournamentId String
  userId       String
  teamCode     String
  draftOdds    Int?
  pickNumber   Int?
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId, teamCode])
  @@unique([tournamentId, pickNumber])
  @@index([tournamentId, userId])
  @@index([userId])
  @@index([tournamentId])
}

model Match {
  id            String    @id @default(cuid())
  externalId    String?   @unique
  tournamentId  String
  stage         String    // "group" | "r32" | "r16" | "qf" | "sf" | "3rd" | "final"
  groupName     String?
  homeTeam      String
  awayTeam      String
  homeScore     Int?
  awayScore     Int?
  penaltyWinner String?   // team code - set when knockout ends on pens
  played        Boolean   @default(false)
  matchDate     DateTime?
  venue         String?
  createdAt     DateTime  @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, stage])
}

model TournamentParticipant {
  tournamentId String
  userId       String
  joinedAt     DateTime @default(now())
  teamName     String?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
}

model EarningsAdjustment {
  id           String   @id @default(cuid())
  tournamentId String
  userId       String
  reason       String
  amountCents  Int
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tournamentId, userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TeamPoints {
  teamCode  String   @id
  points    Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([points])
}

// ── Banter social feed ────────────────────────────────────────

model BanterPost {
  id           String    @id @default(cuid())
  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  authorId     String
  author       User      @relation(fields: [authorId], references: [id])
  text         String
  imageUrl     String?
  gifUrl       String?
  isSystem     Boolean   @default(false)
  systemType   String?   // "pick" | "result"
  systemData   Json?
  createdAt    DateTime  @default(now())
  reactions    BanterReaction[]
  replies      BanterReply[]

  @@index([tournamentId])
  @@index([createdAt])
}

model BanterReaction {
  id     String     @id @default(cuid())
  postId String
  post   BanterPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User       @relation(fields: [userId], references: [id])
  emoji  String

  @@unique([postId, userId, emoji])
  @@index([postId])
}

model BanterReply {
  id        String     @id @default(cuid())
  postId    String
  post      BanterPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User       @relation(fields: [authorId], references: [id])
  text      String
  createdAt DateTime   @default(now())
  reactions BanterReplyReaction[]

  @@index([postId])
}

model BanterReplyReaction {
  id      String      @id @default(cuid())
  replyId String
  reply   BanterReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  userId  String
  user    User        @relation(fields: [userId], references: [id])
  emoji   String

  @@unique([replyId, userId, emoji])
  @@index([replyId])
}

model TeamStagePoints {
  teamCode  String
  stageKey  String
  points    Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([teamCode, stageKey])
  @@index([stageKey])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}
