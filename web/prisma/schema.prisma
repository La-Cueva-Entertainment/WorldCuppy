// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  isAdmin       Boolean   @default(false)

  accounts            Account[]
  sessions            Session[]
  lineupPicks         LineupPick[]
  earningsAdjustments EarningsAdjustment[]
}

model Tournament {
  id             String   @id @default(cuid())
  name           String
  type           String   // "world_cup" | "euros"
  year           Int
  teamsPerPlayer Int      @default(4)
  status         String   @default("upcoming") // "upcoming" | "draft" | "active" | "complete"
  createdAt      DateTime @default(now())

  draft       TournamentDraft?
  picks       LineupPick[]
  matches     Match[]
  adjustments EarningsAdjustment[]
}

model TournamentDraft {
  tournamentId String   @id
  status       String   @default("pending") // "pending" | "active" | "complete"
  orderUserIds String[] @default([])
  currentPick  Int      @default(0)
  updatedAt    DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([status])
}

model LineupPick {
  id           String   @id @default(cuid())
  tournamentId String
  userId       String
  teamCode     String
  draftOdds    Int?
  pickNumber   Int?
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId, teamCode])
  @@unique([tournamentId, pickNumber])
  @@index([tournamentId, userId])
  @@index([userId])
  @@index([tournamentId])
}

model Match {
  id            String    @id @default(cuid())
  tournamentId  String
  stage         String    // "group" | "r32" | "r16" | "qf" | "sf" | "3rd" | "final"
  groupName     String?
  homeTeam      String
  awayTeam      String
  homeScore     Int?
  awayScore     Int?
  penaltyWinner String?   // team code - set when knockout ends on pens
  played        Boolean   @default(false)
  matchDate     DateTime?
  createdAt     DateTime  @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, stage])
}

model EarningsAdjustment {
  id           String   @id @default(cuid())
  tournamentId String
  userId       String
  reason       String
  amountCents  Int
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tournamentId, userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TeamPoints {
  teamCode  String   @id
  points    Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([points])
}

model TeamStagePoints {
  teamCode  String
  stageKey  String
  points    Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([teamCode, stageKey])
  @@index([stageKey])
}
